import subprocess
import pyautogui
import time

# ==========================================
# CONFIGURATION: STORE YOUR CREDENTIALS HERE
# ==========================================
SAP_USER = "YOUR_USER_ID"        # <-- Put your SAP Username here
SAP_PASSWORD = "YOUR_PASSWORD"  # <-- Put your SAP Password here
# ==========================================

def run_sap_desktop_flow():
    try:
        print("1. Opening the App (SAP Logon)...")
        # Opens the native SAP Desktop application executable path
        sap_path = r"C:\Program Files (x86)\SAP\FrontEnd\SAPgui\saplogon.exe"
        subprocess.Popen(sap_path)
        
        # Give the SAP Logon Pad window 5 seconds to open up completely
        time.sleep(5)

        print("2. Action: Enter (Opens the default SAP system connection)")
        pyautogui.press("enter")
        
        # Wait for the actual SAP Client Login screen to display
        time.sleep(4)

        print("3. Action: Entering User ID...")
        # Uses the SAP_USER variable defined above
        pyautogui.write(SAP_USER, interval=0.1) 
        time.sleep(1)

        print("4. Action: Tab (Moves cursor to Password field)")
        pyautogui.press("tab")
        time.sleep(1)

        print("5. Action: Entering Password...")
        # Uses the SAP_PASSWORD variable defined above
        pyautogui.write(SAP_PASSWORD, interval=0.1)
        time.sleep(1)

        print("6. Action: Enter (Logging into the environment)")
        pyautogui.press("enter")
        
        # Give the SAP home dashboard time to load up completely
        print("Waiting for SAP Home Screen to load...")
        time.sleep(8) 

        print("7. Action: Entering Transaction Code 'Zsal_reg'...")
        pyautogui.write("Zsal_reg", interval=0.1)
        time.sleep(1)

        print("8. Action: Enter (Executing Transaction)...")
        pyautogui.press("enter")
        
        print("Flow complete! You are now physically inside the Zsal_reg desktop screen.")
        time.sleep(5)

    except Exception as e:
        print(f"An error occurred: {str(e)}")

if __name__ == "__main__":
    run_sap_desktop_flow()
